{
  "id": "qr-pix",
  "slug": "qr-pix",
  "title": "QR Code Pix",
  "description": "Gere um QR Code Pix 3D para placa, chaveiro ou mesa. O cliente escaneia e paga direto pelo app do banco.",
  "category": "signs",
  "renderStrategy": {
    "type": "three-qr"
  },
  "creditsRequired": 1,
  "parameters": [
    {
      "key": "qrPixKeyType",
      "type": "select",
      "label": "Tipo da chave",
      "default": "cpf",
      "options": ["cpf", "cnpj", "email", "phone", "random"]
    },
    {
      "key": "qrContent",
      "type": "string",
      "label": "Chave Pix",
      "default": ""
    },
    {
      "key": "qrValue",
      "type": "number",
      "label": "Valor R$ (opcional)",
      "default": 0,
      "min": 0,
      "max": 99999,
      "step": 0.01
    },
    {
      "key": "qrIdentifier",
      "type": "string",
      "label": "Identificador (opcional)",
      "default": ""
    },
    {
      "key": "targetSize",
      "type": "number",
      "label": "Tamanho do QR (mm)",
      "default": 50,
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "mm"
    },
    {
      "key": "depth",
      "type": "number",
      "label": "Espessura da base (mm)",
      "default": 3,
      "min": 1,
      "max": 8,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "stampRelief",
      "type": "number",
      "label": "Altura dos módulos (mm)",
      "default": 1.5,
      "min": 0.5,
      "max": 3,
      "step": 0.25,
      "unit": "mm"
    },
    {
      "key": "qrShowBase",
      "type": "boolean",
      "label": "Mostrar base/fundo",
      "default": true
    },
    {
      "key": "color",
      "type": "color",
      "label": "Cor do preview",
      "default": "#1a1a2e"
    }
  ]
}
