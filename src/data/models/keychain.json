{
  "id": "keychain",
  "slug": "keychain",
  "title": "Chaveiro com Texto",
  "description": "Crie um chaveiro personalizado com nome ou texto em relevo. Escolha o formato, fonte e tamanho. Suporta slot para tag NFC.",
  "category": "keychains",
  "renderStrategy": {
    "type": "openscad",
    "scadTemplate": "keychain"
  },
  "creditsRequired": 1,
  "parameters": [
    {
      "key": "text",
      "type": "string",
      "label": "Texto (linha 1)",
      "default": "Forja3D"
    },
    {
      "key": "text2",
      "type": "string",
      "label": "Texto (linha 2, opcional)",
      "default": ""
    },
    {
      "key": "fontSize",
      "type": "number",
      "label": "Tamanho da fonte (mm)",
      "default": 8,
      "min": 4,
      "max": 20,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "shape",
      "type": "select",
      "label": "Formato",
      "default": "retangular_arredondado",
      "options": ["retangular", "retangular_arredondado", "oval"]
    },
    {
      "key": "thickness",
      "type": "number",
      "label": "Espessura total (mm)",
      "default": 4,
      "min": 2,
      "max": 8,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "textDepth",
      "type": "number",
      "label": "Profundidade do relevo (mm)",
      "default": 1.5,
      "min": 0.8,
      "max": 3,
      "step": 0.1,
      "unit": "mm"
    },
    {
      "key": "padding",
      "type": "number",
      "label": "Margem interna (mm)",
      "default": 4,
      "min": 2,
      "max": 10,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "holeDiameter",
      "type": "number",
      "label": "Diâmetro do furo (mm)",
      "default": 6,
      "min": 4,
      "max": 8,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "fontKey",
      "type": "select",
      "label": "Fonte",
      "default": "NotoSans",
      "options": [
        "NotoSans", "Roboto", "OpenSans", "Montserrat", "Lato", "Raleway",
        "Oswald", "Anton", "BebasNeue", "Righteous", "AlfaSlabOne",
        "Pacifico", "DancingScript", "GreatVibes", "Sacramento", "Satisfy",
        "Lobster", "Caveat", "PlayfairDisplay", "Merriweather"
      ]
    },
    {
      "key": "addNfc",
      "type": "boolean",
      "label": "Adicionar slot para tag NFC",
      "default": false
    },
    {
      "key": "color",
      "type": "color",
      "label": "Cor do preview",
      "default": "#f0c040"
    }
  ]
}
