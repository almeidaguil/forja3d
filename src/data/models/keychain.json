      "default": 4,
      "min": 1,
      "max": 10,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "thickness",
      "type": "number",
      "label": "Espessura total (mm)",
      "default": 4,
      "min": 2,
      "max": 8,
      "step": 0.5,
      "unit": "mm"
