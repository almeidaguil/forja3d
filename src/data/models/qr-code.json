{
  "id": "qr-code",
  "slug": "qr-code",
  "title": "QR Code",
  "description": "Gere um QR Code 3D para texto, link ou rede Wi-Fi. Ideal para placas, etiquetas, cardápios e embalagens.",
  "category": "signs",
  "renderStrategy": {
    "type": "three-qr"
  },
  "creditsRequired": 1,
  "parameters": [
    {
      "key": "qrType",
      "type": "select",
      "label": "Tipo de QR",
      "default": "Link",
      "options": ["Link", "Texto", "Wi-Fi"]
    },
    {
      "key": "qrContent",
      "type": "string",
      "label": "Texto ou link",
      "default": ""
    },
    {
      "key": "wifiSsid",
      "type": "string",
      "label": "Nome da rede Wi-Fi",
      "default": ""
    },
    {
      "key": "wifiPassword",
      "type": "string",
      "label": "Senha do Wi-Fi",
      "default": ""
    },
    {
      "key": "wifiSecurity",
      "type": "select",
      "label": "Segurança da rede",
      "default": "WPA",
      "options": ["WPA", "WEP", "Sem senha"]
    },
    {
      "key": "targetSize",
      "type": "number",
      "label": "Tamanho do QR (mm)",
      "default": 50,
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "mm"
    },
    {
      "key": "depth",
      "type": "number",
      "label": "Espessura da base (mm)",
      "default": 3,
      "min": 1,
      "max": 8,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "stampRelief",
      "type": "number",
      "label": "Altura dos módulos (mm)",
      "default": 1.5,
      "min": 0.5,
      "max": 3,
      "step": 0.25,
      "unit": "mm"
    },
    {
      "key": "qrShowBase",
      "type": "boolean",
      "label": "Mostrar base/fundo",
      "default": true
    },
    {
      "key": "color",
      "type": "color",
      "label": "Cor do preview",
      "default": "#14b8a6"
    }
  ]
}
