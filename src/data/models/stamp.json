{
  "id": "stamp",
  "slug": "stamp",
  "title": "Carimbo",
  "description": "Transforme qualquer imagem em um carimbo 3D com relevo. Pixels escuros viram alto relevo; pixels claros/transparentes ficam rentes à base.",
  "category": "stamps",
  "renderStrategy": {
    "type": "three-heightmap",
    "svgSource": "image"
  },
  "creditsRequired": 1,
  "parameters": [
    {
      "key": "baseHeight",
      "type": "number",
      "label": "Altura da base (mm)",
      "default": 5,
      "min": 2,
      "max": 15,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "reliefHeight",
      "type": "number",
      "label": "Altura do relevo (mm)",
      "default": 3,
      "min": 1,
      "max": 8,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "targetSize",
      "type": "number",
      "label": "Tamanho alvo (mm)",
      "default": 60,
      "min": 20,
      "max": 150,
      "step": 5,
      "unit": "mm"
    },
    {
      "key": "threshold",
      "type": "number",
      "label": "Limiar de relevo (%)",
      "default": 35,
      "min": 5,
      "max": 85,
      "step": 5
    },
    {
      "key": "stampResolution",
      "type": "number",
      "label": "Resolução da malha",
      "default": 80,
      "min": 30,
      "max": 200,
      "step": 10
    },
    {
      "key": "mirror",
      "type": "boolean",
      "label": "Espelhar horizontalmente",
      "default": true
    },
    {
      "key": "color",
      "type": "color",
      "label": "Cor do preview",
      "default": "#5b8dd9"
    }
  ]
}
