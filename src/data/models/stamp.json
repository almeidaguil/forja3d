{
  "id": "stamp",
  "slug": "stamp",
  "title": "Carimbo",
  "description": "Transforme qualquer imagem em um carimbo 3D com relevo real. Detalhes internos (olhos, contornos, texto) são preservados como relevos vetoriais via Potrace.",
  "category": "stamps",
  "renderStrategy": {
    "type": "potrace-stamp",
    "svgSource": "image"
  },
  "creditsRequired": 1,
  "parameters": [
    {
      "key": "baseHeight",
      "type": "number",
      "label": "Altura da base (mm)",
      "default": 4,
      "min": 2,
      "max": 15,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "reliefHeight",
      "type": "number",
      "label": "Altura do relevo (mm)",
      "default": 2,
      "min": 0.5,
      "max": 5,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "targetSize",
      "type": "number",
      "label": "Tamanho alvo (mm)",
      "default": 60,
      "min": 20,
      "max": 150,
      "step": 5,
      "unit": "mm"
    },
    {
      "key": "threshold",
      "type": "number",
      "label": "Sensibilidade (limiar)",
      "default": 128,
      "min": 10,
      "max": 245,
      "step": 5
    },
    {
      "key": "turdSize",
      "type": "number",
      "label": "Suprimir manchas (px²)",
      "default": 4,
      "min": 0,
      "max": 30,
      "step": 1
    },
    {
      "key": "bezierSteps",
      "type": "number",
      "label": "Qualidade das curvas",
      "default": 12,
      "min": 4,
      "max": 24,
      "step": 2
    },
    {
      "key": "mirror",
      "type": "boolean",
      "label": "Espelhar horizontalmente",
      "default": true
    },
    {
      "key": "color",
      "type": "color",
      "label": "Cor do preview",
      "default": "#5b8dd9"
    }
  ]
}
