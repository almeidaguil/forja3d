{
  "id": "cookie-cutter",
  "slug": "cookie-cutter",
  "title": "Cortador de Biscoito",
  "description": "Envie uma imagem e gere um cortador de biscoito a partir do seu contorno. Suporta qualquer forma.",
  "category": "cutters",
  "renderStrategy": {
    "type": "three-extrude",
    "svgSource": "image"
  },
  "creditsRequired": 1,
  "parameters": [
    {
      "key": "mode",
      "type": "select",
      "label": "Tipo",
      "default": "Cortador",
      "options": ["Cortador", "Cortador + Carimbo"]
    },
    {
      "key": "cutterHeight",
      "type": "number",
      "label": "Altura total (mm)",
      "default": 12.5,
      "min": 8,
      "max": 50,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "wallThickness",
      "type": "number",
      "label": "Espessura da lâmina (mm)",
      "default": 0.8,
      "min": 0.4,
      "max": 2,
      "step": 0.1,
      "unit": "mm"
    },
    {
      "key": "tipWidth",
      "type": "number",
      "label": "Espessura da ponta (mm)",
      "default": 0.4,
      "min": 0.2,
      "max": 1,
      "step": 0.1,
      "unit": "mm"
    },
    {
      "key": "chamferHeight",
      "type": "number",
      "label": "Altura do chanfro (mm)",
      "default": 2,
      "min": 0.5,
      "max": 5,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "baseWidth",
      "type": "number",
      "label": "Largura da base/pega (mm)",
      "default": 4,
      "min": 2,
      "max": 8,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "baseHeight",
      "type": "number",
      "label": "Altura da base/pega (mm)",
      "default": 3.5,
      "min": 1,
      "max": 8,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "targetSize",
      "type": "number",
      "label": "Tamanho alvo (mm)",
      "default": 70,
      "min": 30,
      "max": 200,
      "step": 5,
      "unit": "mm"
    },
    {
      "key": "threshold",
      "type": "number",
      "label": "Sensibilidade do contorno",
      "default": 128,
      "min": 10,
      "max": 245,
      "step": 1
