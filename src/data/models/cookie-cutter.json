{
  "id": "cookie-cutter",
  "slug": "cookie-cutter",
  "title": "Cortador de Biscoito",
  "description": "Envie uma imagem e gere um cortador de biscoito a partir do seu contorno. Suporta qualquer forma.",
  "category": "cutters",
  "renderStrategy": {
    "type": "three-extrude",
    "svgSource": "image"
  },
  "creditsRequired": 1,
  "parameters": [
    {
      "key": "cutterHeight",
      "type": "number",
      "label": "Altura (mm)",
      "default": 20,
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "mm"
    },
    {
      "key": "wallThickness",
      "type": "number",
      "label": "Espessura da parede (mm)",
      "default": 2,
      "min": 1,
      "max": 5,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "outlineOffset",
      "type": "number",
      "label": "Margem do contorno (mm)",
      "default": 3,
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "mm"
    },
    {
      "key": "targetSize",
      "type": "number",
      "label": "Tamanho alvo (mm)",
      "default": 80,
      "min": 30,
      "max": 200,
      "step": 5,
      "unit": "mm"
    },
    {
      "key": "threshold",
      "type": "number",
      "label": "Sensibilidade do contorno",
      "default": 128,
      "min": 10,
      "max": 245,
      "step": 1
    },
    {
      "key": "color",
      "type": "color",
      "label": "Cor do preview",
      "default": "#e07b54"
    }
  ]
